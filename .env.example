# ============================================================
# AgentX — Environment Configuration
# Copy to .env and fill in all values before running
# ============================================================

# --- Application ---
APP_ENV=production
APP_SECRET_KEY=change-this-to-a-random-64-char-secret
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- Groq API (Free Tier: 14,400 req/day) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.1
GROQ_MAX_RETRIES=3

# --- Supabase (Free Tier: 500MB PostgreSQL) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- GitHub ---
# Default token used if user doesn't supply one
GITHUB_DEFAULT_TOKEN=optional_default_github_token

# --- Docker ---
DOCKER_BASE_IMAGE=python:3.11-slim
DOCKER_NETWORK=agentx-net
DOCKER_TIMEOUT=300
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=1.0

# --- Redis (for job queue / WebSocket pub-sub) ---
REDIS_URL=redis://localhost:6379/0

# --- Render (backend hosting) ---
RENDER_SERVICE_URL=https://agentx-backend.onrender.com

# --- Agent Behaviour ---
AGENT_MAX_PARALLEL=4
VALIDATION_CONFIDENCE_HIGH=90
VALIDATION_CONFIDENCE_MEDIUM=70
FIX_MAX_RETRIES=3
VALIDATION_MAX_ROUNDS=2

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
